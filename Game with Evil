Tabs.Visual:AddButton({"Low Graphics", function()
local decalsYeeted = true
local workspace = game:GetService("Workspace")
local lighting = game:GetService("Lighting")
local terrain = workspace.Terrain

sethiddenproperty(lighting, "Technology", 2)
sethiddenproperty(terrain, "Decoration", false)

local terrainSettings = {
    WaterWaveSize = 0,
    WaterWaveSpeed = 0,
    WaterReflectance = 0,
    WaterTransparency = 0,
}
for s, v in pairs(terrainSettings) do terrain[s] = v end

lighting.GlobalShadows = false
lighting.FogEnd = 9e9
lighting.Brightness = 0
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
wait(1)
local function process(obj)
    if obj:IsA("BasePart") and not obj:IsA("MeshPart") then
        obj.Material = Enum.Material.Plastic
        obj.Reflectance = 0
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        if decalsYeeted then obj.Transparency = 1 end
    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
        obj.Lifetime = NumberRange.new(0)
    elseif obj:IsA("Explosion") then
        obj.BlastPressure = 1
        obj.BlastRadius = 1
    elseif obj:IsA("Fire") or obj:IsA("SpotLight") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
        obj.Enabled = false
    elseif obj:IsA("MeshPart") and decalsYeeted then
        obj.Material = Enum.Material.Plastic
        obj.Reflectance = 0
        obj.TextureID = ""
        wait(1)
    elseif obj:IsA("SpecialMesh") and decalsYeeted then
        obj.TextureId = ""
    elseif obj:IsA("ShirtGraphic") and decalsYeeted then
        obj.Graphic = ""
    elseif obj:IsA("Shirt") and decalsYeeted then
        obj.ShirtTemplate = ""
    elseif obj:IsA("Pants") and decalsYeeted then
        obj.PantsTemplate = ""
    end
end

for _, d in pairs(workspace:GetDescendants()) do process(d) end
end})
